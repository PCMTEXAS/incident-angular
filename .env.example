# ── Supabase ─────────────────────────────────────────────────
# Your Supabase project URL and anon (public) key.
# Found in Supabase Dashboard → Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key — used ONLY by the login Edge Function (server-side).
# NEVER put this in the Angular build or commit it to git.
# Deploy with: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=<value>
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Resend (email notifications, used by api/notify.js) ─────
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxx

# ── Notification recipients ─────────────────────────────────
ADMIN_EMAIL=admin@example.com

# ── Email sender identity ───────────────────────────────────
EMAIL_FROM=DigitalChalk EHS <onboarding@resend.dev>

# ── CORS — comma-separated list of allowed origins ──────────
# e.g. https://incident.example.com,http://localhost:4200
ALLOWED_ORIGINS=https://your-domain.com

# ── Dashboard URL (used in email notification links) ──────────
DASHBOARD_URL=https://your-domain.com/dashboard
