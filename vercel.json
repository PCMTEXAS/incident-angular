{
  "buildCommand": "npx ng build --configuration=production",
  "outputDirectory": "dist/incident-ng/browser",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
